# MongoDB Atlas
MONGODB_ATLAS_URI=<set_your_atlas_uri>
MONGODB_DB_NAME=mineria_peru
MONGODB_COLLECTION_FACT=mineria_observaciones_mensuales
MONGODB_COLLECTION_AGG=mineria_aggregates_mensuales
MONGODB_COLLECTION_PREDICTIONS=predicciones

# Fase 5 - carga MongoDB
PHASE5_LOAD_STRATEGY=incremental
GAP_OK_THRESHOLD_PCT=1
GAP_WARNING_THRESHOLD_PCT=5

# Paths
DATA_RAW_DIR=data/raw
DATA_INTERIM_DIR=data/interim
DATA_PROCESSED_DIR=data/processed
LOG_DIR=logs
REPORT_DIR=reports

# Runtime
PYTHONUTF8=1
LOG_LEVEL=INFO
RANDOM_SEED=42
